{
  "name": "TruckInspection",
  "type": "object",
  "properties": {
    "tenant_id": {
      "type": "string"
    },
    "truck_id": {
      "type": "string"
    },
    "truck_number": {
      "type": "string"
    },
    "driver_id": {
      "type": "string"
    },
    "driver_name": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "inspection_time": {
      "type": "string",
      "description": "Time HH:MM"
    },
    "inspection_type": {
      "type": "string",
      "enum": [
        "pre_trip",
        "post_trip",
        "dot_roadside",
        "annual",
        "random"
      ]
    },
    "inspector_name": {
      "type": "string"
    },
    "inspection_location": {
      "type": "string"
    },
    "result": {
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    },
    "checklist": {
      "type": "object",
      "description": "Key = checklist item, Value = pass | fail | na",
      "additionalProperties": true
    },
    "defects_noted": {
      "type": "string"
    },
    "defects_corrected": {
      "type": "boolean",
      "default": false
    },
    "out_of_service": {
      "type": "boolean",
      "default": false
    },
    "file_url": {
      "type": "string",
      "description": "Inspection report or DOT form"
    },
    "notes": {
      "type": "string"
    },
    "submitted_by_driver": {
      "type": "boolean",
      "default": false
    },
    "pending_review": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "truck_id",
    "date",
    "inspection_type",
    "result",
    "tenant_id"
  ]
}