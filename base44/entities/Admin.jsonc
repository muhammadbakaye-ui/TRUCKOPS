{
  "name": "Admin",
  "type": "object",
  "properties": {
    "first_name": {
      "type": "string"
    },
    "last_name": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "display_email": {
      "type": "string",
      "description": "Email shown to other admins"
    },
    "phone": {
      "type": "string"
    },
    "password_hash": {
      "type": "string"
    },
    "active": {
      "type": "boolean",
      "default": true
    },
    "company_name": {
      "type": "string",
      "description": "Trucking company name for this admin"
    },
    "tenant_id": {
      "type": "string",
      "description": "Links this admin to their Subscription/tenant record"
    },
    "email_verified": {
      "type": "boolean",
      "default": false
    },
    "verification_token": {
      "type": "string"
    },
    "reset_token": {
      "type": "string"
    },
    "reset_token_expires": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "first_name",
    "last_name",
    "email",
    "password_hash"
  ]
}